#!/usr/bin/env python3

import argparse
import csv
import hashlib
import re
import sys
from pathlib import Path


ID_PATTERN = re.compile(r"^(\d+)")


def load_registry(repo_root: Path) -> dict[str, dict]:
    registry_path = repo_root / "raw" / "ingest-registry.tsv"
    try:
        with registry_path.open(encoding="utf-8", newline="") as f:
            rows = csv.DictReader(f, delimiter="\t")
            return {row["broadcast_id"]: row for row in rows}
    except FileNotFoundError:
        print(f"registry not found: {registry_path}", file=sys.stderr)
        sys.exit(1)


def sha256sum(path: Path) -> str:
    hasher = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            hasher.update(chunk)
    return hasher.hexdigest()


def extract_broadcast_id(path: Path) -> str | None:
    match = ID_PATTERN.match(path.name)
    if match:
        return match.group(1)
    return None


def normalize_source_path(path: Path, workspace_root: Path) -> str:
    resolved = path.resolve()
    try:
        return str(resolved.relative_to(workspace_root))
    except ValueError:
        return str(resolved)


def determine_verdict(
    source_path: Path,
    broadcast_id: str | None,
    source_hash: str,
    registry: dict[str, dict],
    workspace_root: Path,
) -> tuple[str, str]:
    if not broadcast_id:
        return "manual-review", "missing-broadcast-id"

    existing = registry.get(broadcast_id)
    if not existing:
        return "new", "not-in-registry"

    normalized_source_path = normalize_source_path(source_path, workspace_root)
    if existing["source_path"] != normalized_source_path:
        return "manual-review", "broadcast-id-conflicts-with-different-source-path"

    if existing["source_hash"] == source_hash:
        return "skip", "same-broadcast-id-and-same-hash"

    return "update-if-changed", "same-broadcast-id-but-hash-differs"


def print_row(row: list[str]) -> None:
    print("\t".join(row))


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Scan dedao/快刀廣播站 and compare files against aiquan-kb ingest registry."
    )
    parser.add_argument(
        "--source-dir",
        default="/Users/lee/ws/myBrainFood/dedao/快刀廣播站",
        help="Directory containing upstream 快刀廣播站 markdown files.",
    )
    parser.add_argument(
        "--only",
        choices=["new", "skip", "update-if-changed", "manual-review", "all"],
        default="all",
        help="Filter output by verdict.",
    )
    parser.add_argument("--id", dest="broadcast_id", help="Only inspect one broadcast_id.")
    args = parser.parse_args()

    repo_root = Path(__file__).resolve().parents[1]
    workspace_root = repo_root.parents[1]
    source_dir = Path(args.source_dir)
    registry = load_registry(repo_root)

    if not source_dir.exists():
        print(f"source dir not found: {source_dir}", file=sys.stderr)
        sys.exit(1)

    print_row(
        [
            "verdict",
            "reason",
            "broadcast_id",
            "source_path",
            "source_hash",
            "registry_raw_file",
            "registry_status",
        ]
    )

    for path in sorted(source_dir.glob("*.md")):
        broadcast_id = extract_broadcast_id(path)
        if args.broadcast_id and broadcast_id != args.broadcast_id:
            continue

        source_hash = sha256sum(path)
        verdict, reason = determine_verdict(
            path, broadcast_id, source_hash, registry, workspace_root
        )
        if args.only != "all" and verdict != args.only:
            continue

        existing = registry.get(broadcast_id or "", {})
        print_row(
            [
                verdict,
                reason,
                broadcast_id or "",
                str(path),
                source_hash,
                existing.get("raw_file", ""),
                existing.get("status", ""),
            ]
        )


if __name__ == "__main__":
    main()
